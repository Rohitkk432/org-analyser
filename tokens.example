# Copy to `tokens` and fill in real values. Never commit secrets.

github-data-token=ghp_your_github_token_here
gitlab_token=glpat_your_gitlab_token_here

# Bitbucket (only if analyzing a Bitbucket workspace/repo).
# Pick ONE credential type and set bitbucket_username to match:
#   1. Atlassian API token (starts with ATATT…, from id.atlassian.com)
#        bitbucket_username = your Atlassian account email  (REQUIRED — the REST
#        API rejects the token without it: "Token is invalid")
#   2. App password (from Bitbucket personal settings)
#        bitbucket_username = your Bitbucket username (not email)
#   3. Workspace/Repository/Project access token
#        leave bitbucket_username blank (authenticates via Bearer)
# bitbucket_token=your_bitbucket_token_here
# bitbucket_username=your_atlassian_email_or_bitbucket_username_here

# ── LLM provider ──────────────────────────────────────────────────────────────
# Use EITHER OpenAI directly, OR Azure AI Foundry / Azure OpenAI.

# Option A — OpenAI directly:
openai_key=sk-your_openai_key_here

# Option B — Azure AI Foundry / Azure OpenAI (leave openai_key blank if using this).
# When AZURE_OPENAI_ENDPOINT is set, every LLM call routes to Azure instead.
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name   # only if it differs from the model name
# OPENAI_API_VERSION=2024-10-21                  # optional; this is the default
